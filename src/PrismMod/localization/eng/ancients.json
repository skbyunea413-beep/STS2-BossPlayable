{
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.0-0.ancient": "You are... not... my warrior...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.0-0.next": "...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.0-1.char": "*a refusing voice*",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.0-1.next": "...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.0-2.ancient": "Turn back... this path... is not yours...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.1-0.ancient": "You return... still... refusing to yield...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.1-0.next": "...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.1-1.char": "*a brief pulse of denial*",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.1-1.next": "...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.1-2.ancient": "Is that silence... your answer... foolish thing...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.2-0.ancient": "The light within you... will not endure...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.2-0.next": "...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.2-1.char": "*a resolute vibration*",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.2-1.next": "...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.2-2.ancient": "Then... climb until... you shatter...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.3-0.ancient": "I did not... call you...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.3-0.next": "...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.3-1.char": "*a sound that does not retreat*",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.3-1.next": "...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.3-2.ancient": "Then... carry the weight... of your choice...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.4-0r.ancient": "Still... you will not turn back...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.4-0r.next": "...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.4-1r.char": "*a refusing voice*",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.4-1r.next": "...",
  "NEOW.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.4-2r.ancient": "Very well... go... to the end...",

  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.0-0.ancient": "Triangle came down?! Why came down?!",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.0-0.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.0-1.char": "*a bored cry*",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.0-1.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.0-2.ancient": "Bored?! Play! Play with me!",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.1-0.ancient": "Came again! Triangle came down again!",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.1-0.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.1-1.char": "*a less bored hum*",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.1-1.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.1-2.ancient": "Good! Today we play more!",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.2-0.ancient": "Triangle not scary now. A little shiny.",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.2-0.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.2-1.char": "*a faint sound of agreement*",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.2-1.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.2-2.ancient": "Yes! Almost friend! Probably!",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.3-0.ancient": "Came down today too! I waited!",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.3-0.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.3-1.char": "*a warm vibration*",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.3-1.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.3-2.ancient": "Orobas not bored. Triangle here, not bored!",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.4-0r.ancient": "Triangle came! We play today too!",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.4-0r.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.4-1r.char": "*a happy cry*",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.4-1r.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.4-2r.ancient": "Friend! Orobas decided!",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.5-0.ancient": "Triangle! Late! Orobas waited!",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.5-0.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.5-1.char": "*an apologetic tremble*",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.5-1.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.5-2.ancient": "Fine! Late friend still friend!",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.6-0.ancient": "Triangle shine is good. Orobas eyes do not hurt!",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.6-0.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.6-1.char": "*a cheerful resonance*",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.6-1.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.6-2.ancient": "Shine more! No, shine only a little more!",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.7-0.ancient": "Today not boring! Reason is triangle!",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.7-0.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.7-1.char": "*a proud cry*",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.7-1.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.7-2.ancient": "Good! Orobas also good friend!",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.8-0.ancient": "Triangle, how high climb today?",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.8-0.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.8-1.char": "*a confident vibration*",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.8-1.next": "...",
  "OROBAS.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.8-2.ancient": "Then go! Orobas goes with heart only!",

  "THE_ARCHITECT.talk.PRISM_MOD_CHARACTER_PRISM_CHARACTER.0-0r.char": "*aggrieved voice*",
